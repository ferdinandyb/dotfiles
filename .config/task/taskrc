# Taskwarrior program configuration file.
# For more documentation, see https://taskwarrior.org or try 'man task', 'man task-color',
# 'man task-sync' or 'man taskrc'

# Here is an example of entries that use the default, override and blank values
#   variable=foo   -- By specifying a value, this overrides the default
#   variable=      -- By specifying no value, this means no default
#   #variable=foo  -- By commenting out the line, or deleting it, this uses the default

# You can also refence environment variables:
#   variable=$HOME/task
#   variable=$VALUE

# Use the command 'task show' to see all defaults and overrides

# Files
data.location=$HOME/.task


# To use the default location of the XDG directories,
# move this configuration file from ~/.taskrc to ~/.config/task/taskrc and uncomment below

#data.location=~/.local/share/task
#hooks.location=~/.config/task/hooks

# Color theme (uncomment one to use)
#include light-16.theme
#include light-256.theme
#include dark-16.theme
#include dark-256.theme
#include dark-red-256.theme
#include dark-green-256.theme
#include dark-blue-256.theme
#include dark-violets-256.theme
#include dark-yellow-green.theme
#include dark-gray-256.theme
#include dark-gray-blue-256.theme
#include /usr/share/taskwarrior/solarized-dark-256.theme
include ~/.config/task/bubblegum-256.theme
#include solarized-dark-256.theme
#include no-color.theme

# report.next.filter = status:pending -WAITING limit:20

# --- Agent-merge readability: keep default views clean of annotations ---
# next is the default for `task` and vit; force description.count ([N] indicator).
report.next.columns=id,start.age,entry.age,depends,priority,project,tags,recur,scheduled.countdown,due.relative,until.remaining,description.count,urgency
# list already defaults to description.count in 3.4.2; pin explicitly for durability.
report.list.columns=id,start.age,entry.age,depends.indicator,priority,project,tags,recur.indicator,scheduled.countdown,due,until.remaining,description.count,urgency

# Explicit annotated view: `task annotated` or `vit annotated`.
report.annotated.description=Task list with annotations shown
report.annotated.columns=id,start.age,entry.age,depends,priority,project,tags,recur,scheduled.countdown,due.relative,until.remaining,description,urgency
report.annotated.labels=ID,Active,Age,Deps,P,Project,Tags,Recur,Sched,Due,Until,Description,Urg
report.annotated.filter=status:pending
report.annotated.sort=urgency-

search.case.sensitive=no
uda.priority.values=H,M,,L # no priority is higher than low
urgency.user.tag.trello.coefficient=-2
urgency.user.tag.github.coefficient=-2
reserved.lines=2

news.version=3.4.1
include ~/.config/task/agent-uda.rc
include ~/.config/task/bugwarrioruda
include ~/.config/task/adhoc-configs
#include ~/.config/task/taskserver
#include ~/.config/task/taskwarrior-tui
